#!/usr/bin/env python3
"""Display a random pokemon sprite with Pokedex entry on terminal open."""

import json
import os
import random
import subprocess
import sys
import time
import urllib.request

CACHE_DIR = os.path.expanduser("~/.cache/pokedex-greeting")
CACHE_FILE = os.path.join(CACHE_DIR, "pokedex.json")
CONFIG_FILE = os.path.join(CACHE_DIR, "config.json")

# Type -> color (ANSI 256-color codes that look good on dark terminals)
TYPE_COLORS = {
    "normal":   "\033[38;2;168;168;120m",
    "fire":     "\033[38;2;240;128;48m",
    "water":    "\033[38;2;104;144;240m",
    "electric": "\033[38;2;248;208;48m",
    "grass":    "\033[38;2;120;200;80m",
    "ice":      "\033[38;2;152;216;216m",
    "fighting": "\033[38;2;192;48;40m",
    "poison":   "\033[38;2;160;64;160m",
    "ground":   "\033[38;2;224;192;104m",
    "flying":   "\033[38;2;168;144;240m",
    "psychic":  "\033[38;2;248;88;136m",
    "bug":      "\033[38;2;168;184;32m",
    "rock":     "\033[38;2;184;160;56m",
    "ghost":    "\033[38;2;112;88;152m",
    "dragon":   "\033[38;2;112;56;248m",
    "dark":     "\033[38;2;112;88;72m",
    "steel":    "\033[38;2;184;184;208m",
    "fairy":    "\033[38;2;238;153;172m",
}

RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"
YELLOW = "\033[38;2;255;215;0m"

DEFAULT_SHINY_RATE = 100

SHINY_PRESETS = [
    ("1/4096", 4096, "Game-accurate (Gen VI+)"),
    ("1/512", 512, "Masuda method"),
    ("1/100", 100, "Practical"),
    ("Custom", 0, "Enter your own 1-in-N rate"),
]

SPARKLE_CHARS = ["✦", "✧", "⋆", "·"]


def load_config():
    """Load config, returning defaults if missing."""
    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE) as f:
            return json.load(f)
    return None


def save_config(config):
    """Write config to disk."""
    os.makedirs(CACHE_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)


def run_setup():
    """Interactive shiny rate picker."""
    print(f"\n{BOLD}Pokedex Greeting — Shiny Setup{RESET}\n")
    print("How rare should shiny encounters be?\n")

    for i, (label, rate, desc) in enumerate(SHINY_PRESETS, 1):
        if rate:
            print(f"  {BOLD}{i}{RESET}) {label}  {DIM}— {desc}{RESET}")
        else:
            print(f"  {BOLD}{i}{RESET}) {label}     {DIM}— {desc}{RESET}")

    print()
    while True:
        try:
            choice = input(f"Pick [{BOLD}1-{len(SHINY_PRESETS)}{RESET}]: ").strip()
            idx = int(choice) - 1
            if 0 <= idx < len(SHINY_PRESETS):
                break
        except (ValueError, EOFError):
            pass
        print("Invalid choice, try again.")

    _, rate, _ = SHINY_PRESETS[idx]

    if rate == 0:
        while True:
            try:
                custom = input(f"Enter rate (1 in {BOLD}N{RESET}): ").strip()
                rate = int(custom)
                if rate >= 1:
                    break
            except (ValueError, EOFError):
                pass
            print("Enter a positive integer.")

    config = {"shiny_rate": rate}
    save_config(config)
    print(f"\n{BOLD}Set!{RESET} Shiny rate: 1/{rate}\n")
    return config


def build_cache():
    """Fetch all pokemon data from PokeAPI and cache locally."""
    os.makedirs(CACHE_DIR, exist_ok=True)

    # Get the pokemon list from pokemon-colorscripts
    program_dir = os.path.dirname(os.path.realpath("/usr/bin/pokemon-colorscripts"))
    with open(os.path.join(program_dir, "pokemon.json")) as f:
        colorscript_pokemon = json.load(f)

    names = [p["name"] for p in colorscript_pokemon]

    print(f"Building Pokedex cache ({len(names)} pokemon)... ", end="", flush=True)

    pokedex = {}
    headers = {"User-Agent": "pokedex-greeting/1.0"}

    def fetch_pokemon(name):
        """Fetch pokemon data, falling back to species endpoint for form variants."""
        # Try direct lookup first
        try:
            url = f"https://pokeapi.co/api/v2/pokemon/{name}"
            req = urllib.request.Request(url, headers=headers)
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read())
                return {"id": data["id"], "types": [t["type"]["name"] for t in data["types"]]}
        except Exception:
            pass

        # Fallback: look up species to find the default variety name
        try:
            url = f"https://pokeapi.co/api/v2/pokemon-species/{name}"
            req = urllib.request.Request(url, headers=headers)
            with urllib.request.urlopen(req, timeout=10) as resp:
                species = json.loads(resp.read())
                default = next(v for v in species["varieties"] if v["is_default"])
                variety_name = default["pokemon"]["name"]

            url = f"https://pokeapi.co/api/v2/pokemon/{variety_name}"
            req = urllib.request.Request(url, headers=headers)
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read())
                return {"id": data["id"], "types": [t["type"]["name"] for t in data["types"]]}
        except Exception:
            pass

        return None

    for i, name in enumerate(names):
        result = fetch_pokemon(name)
        if result:
            pokedex[name] = {"id": result["id"], "name": name, "types": result["types"]}
        else:
            pokedex[name] = {"id": i + 1, "name": name, "types": ["unknown"]}

        # Progress indicator
        if (i + 1) % 50 == 0:
            print(f"{i + 1}", end=".. ", flush=True)

    print("done!")

    with open(CACHE_FILE, "w") as f:
        json.dump(pokedex, f)

    return pokedex


def load_cache():
    """Load cached pokedex data, building it if needed."""
    if os.path.exists(CACHE_FILE):
        with open(CACHE_FILE) as f:
            return json.load(f)
    return build_cache()


def format_type(t):
    """Color-code a pokemon type."""
    color = TYPE_COLORS.get(t, "")
    return f"{color}{BOLD}{t.upper()}{RESET}"


def sparkle_frame(width, height):
    """Generate a frame of random sparkle characters."""
    lines = []
    for _ in range(height):
        line = ""
        for _ in range(width):
            if random.random() < 0.15:
                line += f"{YELLOW}{random.choice(SPARKLE_CHARS)}{RESET}"
            else:
                line += " "
        lines.append(line)
    return "\n".join(lines)


def animate_shiny(sprite_lines):
    """Play sparkle flash frames, then reveal the shiny sprite line-by-line."""
    # Measure sprite dimensions (use raw chars for width estimate)
    height = len(sprite_lines)
    # Approximate visible width from the longest line, stripping ANSI codes
    import re
    ansi_re = re.compile(r"\033\[[0-9;]*m")
    widths = [len(ansi_re.sub("", l)) for l in sprite_lines]
    width = max(widths) if widths else 30

    hide_cursor = "\033[?25l"
    show_cursor = "\033[?25h"
    move_up = f"\033[{height}A"

    sys.stdout.write(hide_cursor)
    sys.stdout.flush()

    try:
        # Phase 1: sparkle flash frames
        for _ in range(3):
            frame = sparkle_frame(width, height)
            sys.stdout.write(frame + "\n")
            sys.stdout.flush()
            time.sleep(0.12)
            sys.stdout.write(move_up + "\r")

        # Clear the sparkle area
        for _ in range(height):
            sys.stdout.write(" " * width + "\n")
        sys.stdout.write(move_up + "\r")

        # Phase 2: line-by-line reveal
        for line in sprite_lines:
            print(line)
            sys.stdout.flush()
            time.sleep(0.02)
    finally:
        sys.stdout.write(show_cursor)
        sys.stdout.flush()


def display(pokemon, shiny=False):
    """Show the sprite with a Pokedex-style info bar."""
    name = pokemon["name"]
    dex_num = pokemon["id"]
    types = pokemon["types"]

    # Get the sprite
    cmd = ["pokemon-colorscripts", "--no-title", "-n", name]
    if shiny:
        cmd.append("-s")
    try:
        sprite = subprocess.run(
            cmd, capture_output=True, text=True, timeout=5,
        ).stdout.rstrip("\n")
    except Exception:
        return

    sprite_lines = sprite.split("\n")

    if shiny:
        animate_shiny(sprite_lines)
    else:
        print(sprite)

    # Format the info line
    display_name = name.replace("-", " ").title()
    type_str = " / ".join(format_type(t) for t in types)
    if shiny:
        info_line = f"{YELLOW}✦{RESET} {DIM}#{dex_num:03d}{RESET}  {BOLD}{display_name}{RESET}  {DIM}[{RESET}{type_str}{DIM}]{RESET}  {YELLOW}✦ SHINY ✦{RESET}"
    else:
        info_line = f"{DIM}#{dex_num:03d}{RESET}  {BOLD}{display_name}{RESET}  {DIM}[{RESET}{type_str}{DIM}]{RESET}"

    print(info_line)
    print()


def is_screensharing():
    """Detect active screensharing via PipeWire.

    Returns True when a screen-capture video source is found in PipeWire
    (created by xdg-desktop-portal during screensharing), while ignoring
    regular webcam devices (v4l2).
    """
    try:
        result = subprocess.run(
            ["pw-dump"], capture_output=True, text=True, timeout=3,
        )
        if result.returncode != 0:
            return False
        nodes = json.loads(result.stdout)
    except Exception:
        return False

    for node in nodes:
        props = node.get("info", {}).get("props", {})
        media_class = props.get("media.class", "")

        # Screen capture sources created by xdg-desktop-portal show up as
        # Video/Source nodes that are *not* backed by v4l2 (webcam).
        # Exclude gamescope which creates Video/Source nodes for gaming,
        # not screensharing.
        node_name = props.get("node.name", "")
        if media_class == "Video/Source" and "api.v4l2.path" not in props and "gamescope" not in node_name:
            return True

        # Some setups surface the portal stream as Stream/Output/Video.
        if media_class == "Stream/Output/Video":
            return True

    return False


def main():
    if "--build-cache" in sys.argv:
        build_cache()
        return

    if "--setup" in sys.argv:
        run_setup()
        return

    # Load or run first-time setup
    config = load_config()
    if config is None:
        config = run_setup()

    no_stealth = "--no-stealth" in sys.argv

    if not no_stealth and is_screensharing():
        return

    shiny_rate = config.get("shiny_rate", DEFAULT_SHINY_RATE)

    pokedex = load_cache()
    name = random.choice(list(pokedex.keys()))
    shiny = "--shiny-test" in sys.argv or random.randint(1, shiny_rate) == 1
    display(pokedex[name], shiny=shiny)


if __name__ == "__main__":
    main()
